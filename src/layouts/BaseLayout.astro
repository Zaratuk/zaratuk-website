---
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import '@styles/global.css';

const {
  title = 'Zaratük Consulting | Power BI Visuals',
  description = 'Zaratük Consulting builds Power BI visuals that solve data quality, validation, and reporting clarity problems.',
  structuredData
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const structuredDataJson = structuredData ? JSON.stringify(structuredData) : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Zaratük Consulting" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {structuredDataJson && <script type="application/ld+json" set:html={structuredDataJson} />}
    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      (() => {
        const formatDownloads = (count) => `${count.toLocaleString()} ${count === 1 ? 'download' : 'downloads'}`;

        const renderDownloadCounts = async () => {
          const nodes = Array.from(document.querySelectorAll('[data-download-count]'));

          if (!nodes.length) {
            return;
          }

          try {
            const response = await fetch('/api/public-download-counts', {
              headers: {
                accept: 'application/json'
              }
            });

            if (!response.ok) {
              return;
            }

            const data = await response.json();
            const totalsByProduct = new Map((data.products ?? []).map((product) => [product.key, product.total]));

            nodes.forEach((node) => {
              const productKey = node.getAttribute('data-download-count');
              const total = totalsByProduct.get(productKey);

              if (typeof total !== 'number') {
                return;
              }

              node.textContent = formatDownloads(total);
              node.closest('[data-download-count-wrapper]')?.classList.remove('hidden');
            });
          } catch {
            // Keep counters hidden if the public counts endpoint is unavailable.
          }
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', renderDownloadCounts, { once: true });
        } else {
          renderDownloadCounts();
        }
      })();
    </script>
  </body>
</html>
