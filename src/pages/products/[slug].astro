---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProductFeatureList from '@components/ProductFeatureList.astro';
import ProductVisualPreview from '@components/ProductVisualPreview.astro';
import products from '@data/products.json';

export function getStaticPaths() {
  return products
    .filter((product) => product.status?.toLowerCase() !== 'coming soon')
    .map((product) => ({
      params: { slug: product.slug },
      props: { product }
    }));
}

const { product } = Astro.props;
const features = product.features.length
  ? product.features
  : [
      {
        title: 'Power BI Report Validation',
        does: product.description,
        matters: 'Keeps validation visible inside Power BI instead of sending analysts to disconnected tools.'
      }
    ];
const steps = product.steps.length
  ? product.steps
  : ['Import the .pbiviz package into Power BI.', 'Add the visual to a report page.', 'Configure checks for the dataset.', 'Review results directly in the report.'];
const fieldRoles = product.fieldRoles ?? [];
const formattingControls = product.formattingControls ?? [];
const showFieldRoles = Boolean(product.showFieldRoles && fieldRoles.length);
const showFormattingControls = Boolean(product.showFormattingControls && formattingControls.length);
---

<BaseLayout
  title={`${product.fullName} | Zaratük Consulting`}
  description={product.description}
>
  <section class="bg-[#f5f5f7] py-16 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-14 px-4 sm:px-6 lg:grid-cols-[0.92fr_1.08fr] lg:px-8 lg:items-center">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-lg bg-white px-3 py-1 text-xs font-semibold text-slate-600 shadow-[0_1px_0_rgba(0,0,0,0.05)]">{product.tag}</span>
          <span class="rounded-lg bg-white px-3 py-1 text-xs font-semibold text-forest-700 shadow-[0_1px_0_rgba(0,0,0,0.05)]">{product.category}</span>
          <span class="rounded-lg bg-white px-3 py-1 text-xs font-semibold text-slate-500 shadow-[0_1px_0_rgba(0,0,0,0.05)]">{product.status}</span>
          {product.pricing && <span class="rounded-lg bg-white px-3 py-1 text-xs font-semibold text-slate-500 shadow-[0_1px_0_rgba(0,0,0,0.05)]">{product.pricing}</span>}
        </div>
        <h1 class="mt-8 text-5xl font-semibold leading-[1.03] tracking-normal text-[#1d1d1f] sm:text-7xl">
          {product.fullName}
        </h1>
        <p class="mt-6 max-w-2xl text-xl leading-8 text-slate-600">{product.description}</p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a class="inline-flex h-12 items-center justify-center rounded-lg bg-forest-950 px-6 text-sm font-semibold text-white transition hover:bg-forest-900" href={product.downloadUrl} download>
            Download pbiviz
          </a>
          {product.sampleDataUrl && (
            <a class="inline-flex h-12 items-center justify-center rounded-lg bg-white px-6 text-sm font-semibold text-[#1d1d1f] shadow-[inset_0_0_0_1px_rgba(0,0,0,0.08)] transition hover:shadow-[inset_0_0_0_1px_rgba(0,0,0,0.2)]" href={product.sampleDataUrl} download>
              Sample data
            </a>
          )}
        </div>
      </div>
      <ProductVisualPreview product={product} />
    </div>
  </section>

  <section class="section-rule bg-white py-20">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[0.75fr_1.25fr] lg:px-8">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-forest-700">What it does</p>
        <h2 class="mt-4 text-4xl font-semibold tracking-normal text-[#1d1d1f]">
          {product.whatItDoesTitle ?? 'Productized validation for Power BI reports.'}
        </h2>
      </div>
      <p class="text-base leading-8 text-slate-600">
        {product.whatItDoesText ?? product.description}
      </p>
    </div>
  </section>

  <section class="section-rule bg-[#f5f5f7] py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-8 max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Features</p>
        <h2 class="mt-4 text-4xl font-semibold tracking-normal text-[#1d1d1f]">{product.featuresTitle ?? 'Designed for focused report workflows.'}</h2>
      </div>
      <ProductFeatureList features={features} />
    </div>
  </section>

  {showFieldRoles && (
    <section class="section-rule bg-white py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Field buckets</p>
          <h2 class="mt-4 text-4xl font-semibold tracking-normal text-[#1d1d1f]">
            {product.fieldRolesTitle ?? 'Purpose-built inputs.'}
          </h2>
          <p class="mt-4 text-sm leading-6 text-slate-600">
            Score formula: <span class="font-semibold text-forest-950">{product.scoreFormula}</span>
          </p>
        </div>
        <div class="grid gap-3">
          {fieldRoles.map((role) => (
            <article class="rounded-lg border border-black/10 bg-[#f5f5f7] p-5">
              <div class="flex flex-wrap items-center justify-between gap-3">
                <h3 class="font-semibold text-[#1d1d1f]">{role.name}</h3>
                <span class="rounded-lg bg-white px-2.5 py-1 text-xs font-semibold text-slate-600">{role.limit}</span>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-600">{role.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {showFormattingControls && (
    <section class="section-rule bg-[#f5f5f7] py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Controls</p>
          <h2 class="mt-4 text-4xl font-semibold tracking-normal text-[#1d1d1f]">
            {product.formattingControlsTitle ?? 'Controls for report-ready layouts.'}
          </h2>
        </div>
        <div class="grid gap-3">
          {formattingControls.map((control) => (
            <div class="rounded-lg bg-white px-5 py-4 text-sm font-medium leading-6 text-slate-700 shadow-[0_10px_30px_rgba(0,0,0,0.04)]">{control}</div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section id="how-to-use" class="section-rule bg-white py-20">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">How to use</p>
        <h2 class="mt-4 text-4xl font-semibold tracking-normal text-[#1d1d1f]">{product.howToUseTitle ?? 'Add the visual, map the fields, review the output.'}</h2>
      </div>
      <ol class="grid gap-3">
        {steps.map((step, index) => (
          <li class="grid grid-cols-[3rem_1fr] items-center rounded-lg border border-black/10 bg-[#f5f5f7]">
            <span class="flex h-full items-center justify-center text-sm font-semibold text-forest-700">{index + 1}</span>
            <span class="px-4 py-4 text-sm font-medium text-slate-700">{step}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section-rule bg-[#f5f5f7] py-20">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[1fr_1fr] lg:px-8">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Use cases</p>
        <h2 class="mt-4 text-4xl font-semibold tracking-normal text-[#1d1d1f]">{product.useCasesTitle ?? 'Built for teams responsible for trusted reporting.'}</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-3">
        {product.useCases.map((useCase) => (
          <div class="rounded-lg bg-white p-5 text-sm font-semibold text-[#1d1d1f] shadow-[0_10px_30px_rgba(0,0,0,0.04)]">{useCase}</div>
        ))}
      </div>
    </div>
  </section>

  <section id="downloads" class="section-rule bg-[#1d1d1f] py-20 text-white">
    <div class="mx-auto grid max-w-7xl gap-8 px-4 sm:px-6 lg:grid-cols-[1fr_auto] lg:items-center lg:px-8">
      <div id="documentation">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-white/50">Get the visual</p>
        <h2 class="mt-4 text-4xl font-semibold tracking-normal">{product.ctaTitle ?? 'Get the visual.'}</h2>
        <p class="mt-4 max-w-2xl text-sm leading-6 text-white/70">
          {product.ctaText ?? 'Download the current package and review installation details.'}
        </p>
      </div>
      <div id="appsource" class="flex flex-col gap-3 sm:flex-row">
        <a class="inline-flex h-12 items-center justify-center rounded-lg bg-white px-6 text-sm font-semibold text-[#1d1d1f] transition hover:bg-slate-100" href={product.downloadUrl} download>
          Download pbiviz
        </a>
        {product.sampleDataUrl && (
          <a class="inline-flex h-12 items-center justify-center rounded-lg border border-white/25 px-6 text-sm font-semibold text-white transition hover:border-white" href={product.sampleDataUrl} download>
            Sample data
          </a>
        )}
        <a class="inline-flex h-12 items-center justify-center rounded-lg border border-white/25 px-6 text-sm font-semibold text-white transition hover:border-white" href={product.documentationUrl}>
          Documentation
        </a>
        <a class="inline-flex h-12 items-center justify-center rounded-lg border border-white/25 px-6 text-sm font-semibold text-white transition hover:border-white" href={product.appSourceUrl}>
          AppSource
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
