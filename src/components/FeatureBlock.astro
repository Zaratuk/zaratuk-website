---
const { eyebrow, title, body } = Astro.props;
---

<article class="border border-forest-950/10 bg-white p-6 shadow-line">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-forest-700">{eyebrow}</p>
  <h3 class="mt-4 text-xl font-semibold tracking-normal text-forest-950">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-slate-600">{body}</p>
</article>
