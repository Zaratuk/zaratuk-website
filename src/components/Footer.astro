---
import ScatterLogo from './ScatterLogo.astro';
---

<footer class="section-rule bg-white">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 md:grid-cols-[1fr_auto] lg:px-8">
    <div>
      <ScatterLogo />
      <p class="mt-4 max-w-xl text-sm leading-6 text-slate-600">
        We build Power BI visuals that solve data quality and reporting problems.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-8 text-sm sm:grid-cols-3">
      <div class="space-y-3">
        <p class="font-semibold text-forest-950">Products</p>
        <a class="block text-slate-600 hover:text-forest-950" href="/products/">Catalog</a>
        <a class="block text-slate-600 hover:text-forest-950" href="/products/data-health-panel/">Data Health Panel</a>
      </div>
      <div class="space-y-3">
        <p class="font-semibold text-forest-950">Future</p>
        <a class="block text-slate-600 hover:text-forest-950" href="/products/data-health-panel/#documentation">Documentation</a>
        <a class="block text-slate-600 hover:text-forest-950" href="/products/data-health-panel/#appsource">AppSource</a>
      </div>
      <div class="space-y-3">
        <p class="font-semibold text-forest-950">Contact</p>
        <a class="block text-slate-600 hover:text-forest-950" href="/contact/">Contact page</a>
        <a class="block text-slate-600 hover:text-forest-950" href="mailto:info@zaratuk.ca">info@zaratuk.ca</a>
      </div>
    </div>
  </div>
</footer>
