---
const { product, featured = false } = Astro.props;
const isComingSoon = product.status?.toLowerCase() === 'coming soon';
---

<article class={`rounded-lg border border-black/10 bg-white/90 p-7 shadow-[0_18px_60px_rgba(0,0,0,0.05)] ${featured ? 'lg:grid lg:grid-cols-[1fr_0.8fr] lg:gap-10' : ''}`}>
  <div>
    <div class="flex flex-wrap items-center gap-2">
      <span class="inline-flex rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">{product.tag}</span>
      <span class="inline-flex rounded-lg bg-emerald-50 px-2.5 py-1 text-xs font-semibold text-forest-700">{product.category}</span>
      {product.pricing && <span class="inline-flex rounded-lg bg-white px-2.5 py-1 text-xs font-semibold text-slate-600 shadow-[inset_0_0_0_1px_rgba(0,0,0,0.08)]">{product.pricing}</span>}
      {isComingSoon && <span class="inline-flex rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-500">Coming soon</span>}
    </div>
    <h3 class="mt-6 text-2xl font-semibold tracking-normal text-[#1d1d1f]">{product.name}</h3>
    <p class="mt-3 text-sm leading-6 text-slate-600">{product.shortDescription ?? product.description}</p>
    {isComingSoon ? (
      <span class="mt-7 inline-flex h-10 items-center justify-center rounded-lg bg-slate-100 px-4 text-sm font-semibold text-slate-500" aria-disabled="true">
        Coming soon
      </span>
    ) : (
      <a class="mt-7 inline-flex h-10 items-center justify-center rounded-lg bg-forest-950 px-4 text-sm font-semibold text-white transition hover:bg-forest-900" href={`/products/${product.slug}/`}>
        View Details
      </a>
    )}
  </div>
  {featured && (
    <div class="mt-8 border border-forest-950/10 bg-slate-50 p-4 lg:mt-0">
      <div class="aspect-[4/3] border border-dashed border-forest-950/20 bg-white p-4">
        <div class="flex h-full flex-col justify-between">
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-forest-700">Power BI visual</span>
            <span class="h-3 w-3 rounded-full bg-forest-400"></span>
          </div>
          <div>
            <div class="h-2 w-full bg-slate-200">
              <div class="h-2 w-[82%] bg-forest-700"></div>
            </div>
            <div class="mt-4 grid grid-cols-4 gap-2">
              <span class="h-16 bg-forest-400/60"></span>
              <span class="h-24 bg-forest-700/80"></span>
              <span class="h-12 bg-forest-950/90"></span>
              <span class="h-20 bg-slate-300"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  )}
</article>
