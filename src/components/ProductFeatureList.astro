---
const { features } = Astro.props;
---

<div class="grid gap-3">
  {features.map((feature) => (
    <article class="grid gap-4 rounded-lg border border-black/10 bg-white p-6 shadow-[0_12px_40px_rgba(0,0,0,0.04)] md:grid-cols-[0.45fr_1fr]">
      <h3 class="text-xl font-semibold text-[#1d1d1f]">{feature.title}</h3>
      <div class="space-y-3">
        <p class="text-sm leading-6 text-slate-700">{feature.does}</p>
        <p class="border-l-2 border-forest-400/70 pl-4 text-sm font-medium leading-6 text-slate-700">{feature.matters}</p>
      </div>
    </article>
  ))}
</div>
