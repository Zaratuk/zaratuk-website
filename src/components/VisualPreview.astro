---
const { compact = false } = Astro.props;
---

<div class="rounded-lg border border-black/10 bg-white shadow-[0_24px_80px_rgba(0,0,0,0.08)]">
  <div class="flex items-center justify-between border-b border-black/10 px-5 py-4">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Data Health Panel</p>
    <span class="h-2.5 w-2.5 rounded-full bg-forest-400"></span>
  </div>
  <div class={`grid gap-4 p-4 ${compact ? '' : 'md:grid-cols-[0.7fr_1fr]'}`}>
    <div class="rounded-lg bg-[#f5f5f7] p-6">
      <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Health score</p>
      <p class="mt-4 text-6xl font-semibold tracking-normal text-[#1d1d1f]">73</p>
      <p class="mt-3 text-sm text-slate-600">Needs attention across 50 rows</p>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div class="rounded-lg bg-slate-50 p-4">
        <p class="text-xs text-slate-500">Completeness</p>
        <p class="mt-3 text-2xl font-semibold text-[#1d1d1f]">86</p>
      </div>
      <div class="rounded-lg bg-slate-50 p-4">
        <p class="text-xs text-slate-500">Freshness</p>
        <p class="mt-3 text-2xl font-semibold text-[#1d1d1f]">70</p>
      </div>
      <div class="rounded-lg bg-slate-50 p-4">
        <p class="text-xs text-slate-500">Uniqueness</p>
        <p class="mt-3 text-2xl font-semibold text-[#1d1d1f]">84</p>
      </div>
      <div class="rounded-lg bg-slate-50 p-4">
        <p class="text-xs text-slate-500">Validity</p>
        <p class="mt-3 text-2xl font-semibold text-[#1d1d1f]">69</p>
      </div>
    </div>
  </div>
  <div class="border-t border-black/10 p-4">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Issue List</p>
    <div class="mt-3 grid gap-2">
      <p class="rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700">Data is 2.8 days old</p>
      <p class="rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700">8 duplicate CaseID values detected</p>
      <p class="rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700">Low-frequency categories detected in Status</p>
    </div>
  </div>
</div>
