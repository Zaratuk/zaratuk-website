---
---

<section class="relative overflow-hidden bg-[radial-gradient(circle_at_18%_16%,rgba(107,174,110,0.18),transparent_34%),radial-gradient(circle_at_82%_18%,rgba(242,200,17,0.12),transparent_28%),#f5f5f7]">
  <div class="pointer-events-none absolute inset-0 opacity-[0.22] [background-image:radial-gradient(rgba(15,45,31,0.18)_1px,transparent_1px)] [background-size:22px_22px]"></div>
  <div class="relative mx-auto grid max-w-7xl items-center gap-10 px-4 pb-16 pt-14 sm:px-6 md:grid-cols-[1.02fr_0.98fr] lg:px-8 lg:pb-24 lg:pt-20">
    <div>
      <div class="inline-flex items-center gap-2 rounded-lg border border-forest-700/25 bg-emerald-50 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-forest-900 shadow-[0_1px_0_rgba(0,0,0,0.04)]">
        <span class="h-1.5 w-8 rounded-full bg-powerbi-500"></span>
        Power BI Custom Visuals Developer
      </div>
      <h1 class="mt-8 max-w-4xl text-5xl font-semibold leading-[1.02] tracking-normal text-[#1d1d1f] sm:text-6xl lg:text-7xl">
        Power BI visuals built for better data decisions.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        Custom pbiviz tools designed to improve data quality, validation, and reporting clarity inside Power BI.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a class="inline-flex h-12 items-center justify-center rounded-lg bg-forest-950 px-6 text-sm font-semibold text-white transition hover:bg-forest-900" href="/products/">
          Explore visuals
        </a>
        <a class="inline-flex h-12 items-center justify-center rounded-lg border border-forest-950 bg-white px-6 text-sm font-semibold text-forest-950 transition hover:bg-emerald-50" href="/products/data-health-panel/">
          View product
        </a>
      </div>
    </div>
    <div class="relative">
      <div class="rounded-lg border border-black/10 bg-white shadow-[0_24px_80px_rgba(0,0,0,0.08)]">
        <div class="flex items-center justify-between border-b border-black/10 px-4 py-3">
          <div class="flex gap-2">
            <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-forest-400"></span>
          </div>
          <span class="text-xs font-medium text-slate-500">Data Health Panel.pbiviz</span>
        </div>
        <div class="grid gap-0 md:grid-cols-[0.7fr_1fr]">
          <div class="border-b border-black/10 bg-[#f5f5f7] p-5 md:border-b-0 md:border-r">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Quality score</p>
            <p class="mt-4 text-6xl font-semibold text-amber-700">73</p>
            <div class="mt-5 h-2 bg-slate-200">
              <div class="h-2 w-[73%] bg-amber-500"></div>
            </div>
            <p class="mt-4 text-sm leading-6 text-slate-600">Needs attention across 50 rows.</p>
          </div>
          <div class="p-5">
            <div class="grid grid-cols-3 gap-3">
              <div class="rounded-lg bg-slate-50 p-3">
                <p class="text-xs text-slate-500">Completeness</p>
                <p class="mt-2 text-2xl font-semibold text-forest-700">86</p>
              </div>
              <div class="rounded-lg bg-slate-50 p-3">
                <p class="text-xs text-slate-500">Uniqueness</p>
                <p class="mt-2 text-2xl font-semibold text-forest-700">84</p>
              </div>
              <div class="rounded-lg bg-slate-50 p-3">
                <p class="text-xs text-slate-500">Freshness</p>
                <p class="mt-2 text-2xl font-semibold text-amber-700">70</p>
              </div>
            </div>
            <div class="mt-5 space-y-3">
              <div class="flex items-center justify-between rounded-lg bg-slate-50 px-3 py-2">
                <span class="text-sm text-slate-700">Data is 2.8 days old</span>
                <span class="text-sm font-semibold text-amber-700">Freshness</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-slate-50 px-3 py-2">
                <span class="text-sm text-slate-700">8 duplicate CaseID values</span>
                <span class="text-sm font-semibold text-forest-700">Uniqueness</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-slate-50 px-3 py-2">
                <span class="text-sm text-slate-700">Low-frequency categories</span>
                <span class="text-sm font-semibold text-forest-700">Validity</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
